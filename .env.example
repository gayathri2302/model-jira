# Server
PORT=3001
NODE_ENV=development

# MSSQL — single connection string
DATABASE_URL=sqlserver://localhost:1433;database=model_jira;user=your_user;password=your_password;encrypt=false;trustServerCertificate=true

# JWT
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_EXPIRES_IN=8h

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_STORAGE_CONTAINER=jira-attachments

# CORS
CLIENT_ORIGIN=http://localhost:5173
