# Copy this file to scripts/.env and fill in your values
# DATABASE_URL is automatically read from server/.env — no need to repeat it here

# Jira credentials
JIRA_URL=https://your-jira-instance.example.com
JIRA_USER=your_username
JIRA_PASS=your_password

# Default project settings for imported tickets
JIRA_PROJECT_KEY=IMPORT
JIRA_PROJECT_NAME=Imported Project

# Optional: UUID of the user who will own the created project
# If not set, the first user in the DB is used
# IMPORT_OWNER_ID=
